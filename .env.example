# ContractPeer - Environment Variables Template
# Copy to .env and fill in actual values. NEVER commit .env to git.
# On Hostinger, these can be set via:
#   1. A .env file loaded by PHP (requires a dotenv library)
#   2. Apache SetEnv directives in .htaccess (preferred)
#   3. PHP-FPM pool configuration

# Stripe (restricted key only - no payout/bank/settings access)
STRIPE_SECRET_KEY=rk_live_your_restricted_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# LLM API (choose one provider)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o

# OR use Anthropic:
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-anthropic-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# App
APP_ENV=production
APP_URL=https://contractpeer.com
SUPPORT_EMAIL=support@contractpeer.com
